# ================================================================
# Customer Sentiment Analysis & Business Insight Engine
# Environment Configuration — Copy to .env and fill in values
# ================================================================

# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
DEBUG=false

# ── Security ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentiment_engine
POSTGRES_USER=sentiment_user
POSTGRES_PASSWORD=sentiment_dev_pass

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=data/embeddings/chroma

# ── OpenAI / LLM (for AI-generated reports) ──────────────────────
# Option 1: OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview
LLM_PROVIDER=openai

# Option 2: Ollama (free, offline)
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── ML Models ────────────────────────────────────────────────────
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
BATCH_SIZE=32
USE_GPU=false
DEVICE=cpu

# ── Churn Thresholds ─────────────────────────────────────────────
CHURN_HIGH_RISK_THRESHOLD=0.7
CHURN_MEDIUM_RISK_THRESHOLD=0.4

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=sentiment-analysis

# ── Feature Flags ────────────────────────────────────────────────
ENABLE_LLM_INSIGHTS=true
ENABLE_CHURN_PREDICTION=true
ENABLE_TOPIC_MODELING=true
ENABLE_SARCASM_DETECTION=true
ENABLE_RAG=true
ENABLE_AGENTS=true

# ── Data Source APIs (optional) ──────────────────────────────────
YELP_API_KEY=
GOOGLE_PLACES_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=sentiment123
